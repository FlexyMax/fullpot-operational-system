# Copy this file to .env.production on the server and fill in all values.
# NEVER commit .env.production to GitHub.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=flexymaxfpsql.public.9a4b26c7b85f.database.windows.net
DB_PORT=3342
DB_USER=azure
DB_PASSWORD=YOUR_DB_PASSWORD
DB_NAME=fullpot
DB_SISTEMA_NAME=sistema
DB_TRUST_CERT=true

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Must match the public URL of the app (your Cloudflare tunnel domain)
NEXTAUTH_URL=https://YOUR_TUNNEL_DOMAIN.com
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET_MIN_32_CHARS

# ── Company ───────────────────────────────────────────────────────────────────
COMPANY_ID=R7X98780

# ── Digital Ocean Spaces (file uploads) ───────────────────────────────────────
DO_SPACES_KEY=YOUR_DO_SPACES_KEY
DO_SPACES_SECRET=YOUR_DO_SPACES_SECRET
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=flexymax
DO_SPACES_REGION=nyc3

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
TUNNEL_TOKEN=YOUR_CLOUDFLARE_TUNNEL_TOKEN
